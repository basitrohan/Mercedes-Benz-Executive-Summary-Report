    <worksheet name='KPI(Profit Margin-CY)'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#999999' fontname='Tableau Semibold' fontsize='12'>Profit Margin</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Bold' fontsize='18'><![CDATA[<[federated.09jrixn1p51if711b2frz14z2pqc].[sum:Calculation_1301055334666249:qk]>]]></run>
            <run>Æ&#10;</run>
            <run fontcolor='#666666' fontname='Tableau Semibold' fontsize='10'><![CDATA[<[federated.09jrixn1p51if711b2frz14z2pqc].[sum:Calculation_1301055334694922:qk]>]]></run>
            <run fontname='Tableau Semibold' fontsize='10'>Æ </run>
            <run fontcolor='#c0c0c0' fontname='Tableau Semibold' fontsize='10'>vs Py</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='core_sales_dataset' name='federated.09jrixn1p51if711b2frz14z2pqc' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Year' datatype='integer' default-format='n0;-0' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.09jrixn1p51if711b2frz14z2pqc'>
            <column caption='%Diff Profit Margin' datatype='real' default-format='p0.0%' name='[%Diff Revenue (copy)_1301055328911365]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([CY Revenue (copy)_1301055328137219])-SUM([PY Revenue (copy)_1301055328768004]))/SUM([PY Revenue (copy)_1301055328768004])' />
            </column>
            <column caption='CY Profit Margin' datatype='real' default-format='c&quot;$&quot;#,##0,,M;(&quot;$&quot;#,##0,,M)' name='[CY Revenue (copy)_1301055328137219]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([order_date]) = [Parameters].[Parameter 1] THEN [profit_margin]&#13;&#10;END' />
            </column>
            <column caption='{SUM([CY Profit Margin])}' datatype='real' name='[Calculation_1301055334666249]' role='measure' type='quantitative' user:unnamed='KPI(Profit Margin-CY)'>
              <calculation class='tableau' formula='{SUM([CY Revenue (copy)_1301055328137219])}' />
